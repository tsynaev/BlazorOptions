@using BlazorOptions.ViewModels
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using System.Collections.ObjectModel
@using System.Linq

@if (ClosedPositionsViewModel is not null)
{
    <MudCard Class="closed-positions-card">
        <MudCardHeader>
            <MudStack Spacing="1" Class="flex-grow-1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="closed-positions-header-row">
                    <MudCheckBox T="bool"
                                 Value="@ClosedPositionsViewModel.Model.Include"
                                 ValueChanged="async value => await ClosedPositionsViewModel.SetIncludeAsync(value)"
                                 />
                    <MudText Typo="Typo.h6">Trades</MudText>
                    <MudText Typo="Typo.caption" Class="closed-positions-summary">
                        Net: @TradesViewModel.TotalNet.ToString("0.##")
                    </MudText>
                    <MudText Typo="Typo.caption" Class="closed-positions-summary">
                        PnL: @TradesViewModel.TotalClosePnl.ToString("0.##") | Fee: @TradesViewModel.TotalFee.ToString("0.##")
                    </MudText>
                    <MudSpacer />
                </MudStack>
            </MudStack>
        </MudCardHeader>
        <MudCardContent>
            @if (TradesViewModel is not null)
            {
                @if (TradesViewModel.IsLoading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                }

                if (TradesViewModel.Trades.Count == 0)
                {
                    <MudText Typo="Typo.body2">
                        @(TradesViewModel.IsLoading ? "Loading trades..." : "No trades found for the tracked symbols.")
                    </MudText>
                }
                else
                {
                    <MudTable Items="TradesViewModel.Trades"
                              Dense="true"
                              Hover="true"
                              Class="closed-positions-table mb-4">
                        <HeaderContent>
                            <MudTh>Symbol</MudTh>
                            <MudTh>Size</MudTh>
                            <MudTh>PnL</MudTh>
                            <MudTh>Open</MudTh>
                            <MudTh>Close</MudTh>
                            <MudTh>Fee</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Symbol">
                                <MudStack Spacing="0">
                                    <MudLink OnClick="() => OpenSymbolDialogAsync(context.Symbol, context.SinceDate)">@context.Symbol</MudLink>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Summary.Direction</MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Size">@FormatNumber(context.Summary.Size)</MudTd>
                            <MudTd DataLabel="PnL">
                                <MudText Typo="Typo.body2" Color="@ResolvePnlColor(context.Summary.Pnl)">
                                    @FormatMoney(context.Summary.Pnl)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="Open">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@FormatMoney(context.Summary.EntryPrice)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="closed-positions-time-caption">
                                        @FormatTimeRange(context.Summary.EntryStartTimestamp, context.Summary.EntryEndTimestamp)
                                    </MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Close">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@FormatMoney(context.Summary.ClosePrice)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="closed-positions-time-caption">
                                        @FormatTimeRange(context.Summary.CloseStartTimestamp, context.Summary.CloseEndTimestamp)
                                    </MudText>
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Fee">@FormatMoney(context.Summary.Fee)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="closed-positions-input-row mb-4">
                <MudTextField T="string"
                              @bind-Value="ClosedPositionsViewModel.AddSymbolInput"
                              Label="Add symbols"
                              Placeholder="Paste symbols, one per line"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              OnKeyDown="HandleAddSymbolKeyDown"
                              Lines="4"
                              Class="closed-positions-symbol-input" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="async () => await ClosedPositionsViewModel.AddSymbolAsync()">
                    Add
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="OpenTradesDialogAsync">
                    Select trades
                </MudButton>
            </MudStack>
            <MudTable Items="ClosedPositionsViewModel.ClosedPositions"
                      Dense="true"
                      Hover="true"
                      Class="closed-positions-table">
                <HeaderContent>
                    <MudTh>Symbol</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <ClosedPositionRow ViewModel="context" OwnerViewModel="ClosedPositionsViewModel" OnOpenSymbolDialog="OpenSymbolDialogAsync" @key="context.Model.Id" />
                </RowTemplate>
            </MudTable>
        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter, EditorRequired] public ClosedPositionsViewModel ClosedPositionsViewModel { get; set; } = default!;
    [Parameter, EditorRequired] public TradesViewModel TradesViewModel { get; set; } = default!;
    [Parameter, EditorRequired] public string ExchangeConnectionId { get; set; } = string.Empty;

    [Inject] private INavigationService NavigationService { get; set; } = default!;

    private ClosedPositionsViewModel? _lastViewModel;

    protected override void OnParametersSet()
    {
        if (ClosedPositionsViewModel is null)
        {
            return;
        }

        if (!ReferenceEquals(_lastViewModel, ClosedPositionsViewModel))
        {
            _lastViewModel = ClosedPositionsViewModel;
            _ = ClosedPositionsViewModel.InitializeAsync();
        }
    }

    protected override void OnInitialized()
    {
        ClosedPositionsViewModel.PropertyChanged += (_, _) => InvokeAsync(StateHasChanged);
        ClosedPositionsViewModel.ClosedPositions.CollectionChanged += (_, _) => InvokeAsync(StateHasChanged);
        TradesViewModel.PropertyChanged += (_, _) => InvokeAsync(StateHasChanged);
    }

    private Task HandleAddSymbolKeyDown(KeyboardEventArgs args)
    {
        return ClosedPositionsViewModel.OnAddSymbolKeyDown(args.Key, args.CtrlKey, args.MetaKey);
    }


    private async Task OpenSymbolDialogAsync(string symbol, DateTime? sinceDate)
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            return;
        }

        await NavigationService.NavigateToAsync<TradingSymbolDialogViewModel>(viewModel =>
            viewModel.LoadAsync(
                symbol,
                string.Empty,
                ClosedPositionsViewModel.ResolveEffectiveSinceDateLocal(sinceDate),
                ExchangeConnectionId));
    }

    private async Task OpenTradesDialogAsync()
    {
        var existingSymbols = ClosedPositionsViewModel.ClosedPositions
            .Select(item => item.Model.Symbol)
            .Where(symbol => !string.IsNullOrWhiteSpace(symbol))
            .ToList();

        var baseAsset = ClosedPositionsViewModel.BaseAsset;
        var dialogViewModel = await NavigationService.NavigateToAsync<TradingHistorySelectionDialogViewModel>(
            viewModel => viewModel.InitializeAsync(existingSymbols, baseAsset, ExchangeConnectionId));

        var selectedSymbols = await dialogViewModel.WaitForSelectionAsync();
        if (selectedSymbols is null || selectedSymbols.Count == 0)
        {
            return;
        }

        ClosedPositionsViewModel.SetAddSymbolInput(selectedSymbols);
        await ClosedPositionsViewModel.AddSymbolAsync();
    }

    private static string FormatNumber(decimal value)
    {
        return value.ToString("0.##########", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string FormatMoney(decimal value)
    {
        var abs = Math.Abs(value);
        var format = abs >= 0.01m || abs == 0m
            ? "0.##"
            : "0.##########";
        return value.ToString(format, System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string FormatMoney(decimal? value)
    {
        return value.HasValue ? FormatMoney(value.Value) : string.Empty;
    }

    private static string FormatTimestamp(long? timestamp)
    {
        if (!timestamp.HasValue || timestamp.Value <= 0)
        {
            return "N/A";
        }

        try
        {
            return DateTimeOffset.FromUnixTimeMilliseconds(timestamp.Value)
                .ToLocalTime()
                .ToString("g", System.Globalization.CultureInfo.CurrentCulture);
        }
        catch
        {
            return "N/A";
        }
    }

    private static string FormatTimeRange(long? startTimestamp, long? endTimestamp)
    {
        if (!startTimestamp.HasValue || !endTimestamp.HasValue)
        {
            return string.Empty;
        }

        var start = ToLocalDateTime(startTimestamp.Value);
        var end = ToLocalDateTime(endTimestamp.Value);
        if (!start.HasValue || !end.HasValue)
        {
            var startText = FormatTimestamp(startTimestamp.Value);
            var endText = FormatTimestamp(endTimestamp.Value);
            return string.Equals(startText, endText, StringComparison.Ordinal)
                ? startText
                : $"{startText} -> {endText}";
        }

        if (start.Value == end.Value)
        {
            return start.Value.ToString("g", System.Globalization.CultureInfo.CurrentCulture);
        }

        if (start.Value.Date == end.Value.Date)
        {
            var startText = start.Value.ToString("g", System.Globalization.CultureInfo.CurrentCulture);
            var endText = end.Value.ToString("t", System.Globalization.CultureInfo.CurrentCulture);
            return $"{startText} -> {endText}";
        }

        return $"{start.Value.ToString("g", System.Globalization.CultureInfo.CurrentCulture)} -> {end.Value.ToString("g", System.Globalization.CultureInfo.CurrentCulture)}";
    }

    private static DateTime? ToLocalDateTime(long timestamp)
    {
        if (timestamp <= 0)
        {
            return null;
        }

        try
        {
            return DateTimeOffset.FromUnixTimeMilliseconds(timestamp).ToLocalTime().DateTime;
        }
        catch
        {
            return null;
        }
    }

    private static Color ResolvePnlColor(decimal? pnl)
    {
        if (!pnl.HasValue)
        {
            return Color.Default;
        }

        if (pnl.Value > 0m)
        {
            return Color.Success;
        }

        if (pnl.Value < 0m)
        {
            return Color.Error;
        }

        return Color.Default;
    }
}

<style>
    .closed-positions-card .mud-card-header-content {
        width: 100%;
    }

    .closed-positions-summary {
        opacity: 0.8;
    }

    .closed-positions-symbol-input {
        min-width: 220px;
    }

    .closed-positions-since-date {
        width: 120px;
        min-width: 120px;
    }

    .closed-positions-since-time {
        width: 110px;
        min-width: 110px;
    }

    .closed-positions-time-caption {
        font-size: 0.68rem;
        line-height: 1.1;
    }

    @@media (max-width: 600px) {
        .closed-positions-header-row {
            flex-wrap: wrap;
            gap: 8px;
        }

        .closed-positions-summary {
            display: block;
            width: 100%;
        }

        .closed-positions-input-row {
            flex-direction: column;
            align-items: stretch;
        }

        .closed-positions-symbol-input {
            width: 100%;
            min-width: 0;
        }
    }
</style>
