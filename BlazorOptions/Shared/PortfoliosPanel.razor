@using BlazorOptions.ViewModels

@if (ViewModel is not null)
{
    <MudStack Spacing="2">
        @if (ViewModel.LegsCollection?.Collection is not null)
        {
            <LegsPanel ViewModel="@ViewModel.LegsCollection" @key="ViewModel.LegsCollection.Collection.Id" />
        }
    </MudStack>
}

@code {
    [Parameter, EditorRequired] public PositionViewModel? ViewModel { get; set; }
}
