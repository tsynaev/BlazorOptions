@using System.Globalization
@using BlazorOptions.ViewModels
@using MudBlazor

<MudDialog Class="leg-edit-dialog">
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="LegType"
                       Label="Type"
                       Value="@ViewModel.Leg.Type"
                       ValueChanged="ViewModel.UpdateLegTypeAsync"
                       Dense="true"
                       Disabled="@ViewModel.Leg.IsReadOnly">
                @foreach (var type in ViewModel.LegTypes)
                {
                    <MudSelectItem Value="@type" @key="type">@type</MudSelectItem>
                }
            </MudSelect>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @if (ViewModel.Leg.Type != LegType.Spot)
                {
                    <MudSelect T="DateTime?"
                               Label="Expiration"
                               Value="@ViewModel.Leg.ExpirationDate"
                               ValueChanged="ViewModel.UpdateLegExpirationAsync"
                               Dense="true"
                               Disabled="@ViewModel.Leg.IsReadOnly">
                        @if (IsUnderlyingLegType(ViewModel.Leg.Type))
                        {
                            <MudSelectItem T="DateTime?" Value="@((DateTime?)null)">Perpetual</MudSelectItem>
                        }

                        @if (ViewModel.AvailableExpirations.Count == 0)
                        {
                            @if (!IsUnderlyingLegType(ViewModel.Leg.Type))
                            {
                                <MudSelectItem T="DateTime?" Disabled="true">No expirations available</MudSelectItem>
                            }
                        }
                        else
                        {
                            @foreach (var expiration in ViewModel.AvailableExpirations.Where(item => item.HasValue))
                            {
                                <MudSelectItem T="DateTime?" Value="@expiration" @key="expiration">@FormatExpiration(expiration)</MudSelectItem>
                            }
                        }
                    </MudSelect>
                }

                @if (!IsUnderlyingLegType(ViewModel.Leg.Type))
                {
                    <MudSelect T="decimal?"
                               Label="Strike"
                               Value="@ViewModel.Leg.Strike"
                               ValueChanged="ViewModel.UpdateLegStrikeAsync"
                               Dense="true"
                               Disabled="@(ViewModel.Leg.IsReadOnly || !ViewModel.Leg.ExpirationDate.HasValue)">
                        @foreach (var strike in ViewModel.AvailableStrikes)
                        {
                            <MudSelectItem T="decimal?" Value="@strike" @key="strike">@strike.ToString("0.##")</MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudStack>

            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     @key="_sizeFieldKey"
                                     Label="Size"
                                     @bind-Value="SizeValue"
                                     Format="0.##"
                                     Margin="Margin.Dense"
                                     Disabled="@ViewModel.Leg.IsReadOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal?"
                                     @key="_priceFieldKey"
                                     Label="Price"
                                     Value="@ViewModel.Leg.Price"
                                     ValueChanged="OnPriceChangedAsync"
                                     Format="0.##"
                                     Margin="Margin.Dense"
                                     Adornment="Adornment.End"
                                     AdornmentText="USDT"
                                     Placeholder="@FormatPrice(GetPricePlaceholder())"
                                     Disabled="@ViewModel.Leg.IsReadOnly" />
                </MudItem>
            </MudGrid>

            @if (!IsUnderlyingLegType(ViewModel.Leg.Type))
            {
                <MudNumericField T="decimal?"
                                 Label="IV"
                                 Value="@ViewModel.Leg.ImpliedVolatility"
                                 ValueChanged="ViewModel.UpdateLegIvAsync"
                                 Margin="Margin.Dense"
                                 Adornment="Adornment.End"
                                 AdornmentText="%"
                                 Placeholder="@FormatPrice(GetIvPlaceholder())"
                                 Disabled="@ViewModel.Leg.IsReadOnly" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudText Typo="Typo.caption" Class="leg-edit-symbol">@GetSymbolLabel()</MudText>
        <MudSpacer />
        <MudButton OnClick="SaveAsync" Disabled="@ViewModel.Leg.IsReadOnly">Save</MudButton>
        <MudButton Color="Color.Secondary" OnClick="CancelAsync">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter, EditorRequired] public LegViewModel ViewModel { get; set; } = default!;

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    private decimal _sizeValue;
    private string _sizeFieldKey = string.Empty;
    private string _priceFieldKey = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        SyncEditableFields();
        await ViewModel.EnsureFutureExpirationsLoadedAsync();
        await InvokeAsync(StateHasChanged);
    }

    protected override void OnParametersSet()
    {
        SyncEditableFields();
    }

    private Task SaveAsync()
    {
        MudDialog.Close(DialogResult.Ok(true));
        return Task.CompletedTask;
    }

    private Task CancelAsync()
    {
        MudDialog.Cancel();
        return Task.CompletedTask;
    }

    private static string FormatPrice(decimal? price)
    {
        return price.HasValue ? price.Value.ToString("0.##", CultureInfo.InvariantCulture) : string.Empty;
    }

    private static string FormatExpiration(DateTime? date)
    {
        return date.HasValue ? date.Value.ToString("yyyy-MM-dd") : "Perpetual";
    }

    private void SyncEditableFields()
    {
        _sizeValue = ViewModel.Leg.Size;

        // Key forces a clean MudNumericField state when the edited leg changes.
        _sizeFieldKey = $"{ViewModel.Leg.ReferenceId ?? ViewModel.Leg.Symbol ?? "leg"}:{ViewModel.Leg.Size.ToString(CultureInfo.InvariantCulture)}";
        _priceFieldKey = $"{ViewModel.Leg.ReferenceId ?? ViewModel.Leg.Symbol ?? "leg"}:{(ViewModel.Leg.Price.HasValue ? ViewModel.Leg.Price.Value.ToString(CultureInfo.InvariantCulture) : "null")}";
    }

    private decimal SizeValue
    {
        get => _sizeValue;
        set
        {
            if (_sizeValue == value)
            {
                return;
            }

            _sizeValue = value;
            ViewModel.UpdateLegSizeAsync(value);
        }
    }

    private decimal? GetPricePlaceholder()
    {
        if (ViewModel.Leg.Price.HasValue)
        {
            return null;
        }

        if (IsUnderlyingLegType(ViewModel.Leg.Type))
        {
            // Futures placeholder should reflect current underlying mark when entry is empty.
            return ViewModel.MarkPrice ?? ViewModel.IndexPrice ?? ViewModel.PlaceholderPrice;
        }

        return ViewModel.MarkPrice ?? ViewModel.PlaceholderPrice;
    }

    private async Task OnPriceChangedAsync(decimal? value)
    {
        await ViewModel.UpdateLegPriceAsync(value);
    }

    private decimal? GetIvPlaceholder()
    {
        if (ViewModel.Leg.ImpliedVolatility.HasValue)
        {
            return null;
        }

        return ViewModel.ChainIv;
    }

    private string GetSymbolLabel()
    {
        return string.IsNullOrWhiteSpace(ViewModel.Leg.Symbol)
            ? "-"
            : ViewModel.Leg.Symbol.ToUpperInvariant();
    }

    private static bool IsUnderlyingLegType(LegType type)
    {
        return type is LegType.Future or LegType.Spot;
    }
}

<style>
    .leg-edit-dialog .mud-dialog {
        width: 100%;
        max-width: 600px;
    }

    .leg-edit-symbol {
        opacity: 0.7;
        font-family: monospace;
    }

    @@media (max-width: 600px) {
        .leg-edit-dialog .mud-dialog {
            width: 100vw !important;
            max-width: 100vw !important;
            margin: 0;
            border-radius: 0;
        }
    }
</style>
