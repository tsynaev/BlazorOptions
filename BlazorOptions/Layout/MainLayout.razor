@inherits LayoutComponentBase
@implements IDisposable
@inject BlazorOptions.ViewModels.MainLayoutViewModel ViewModel

<MudLayout>
    <MudAppBar Fixed="false" Class="main-appbar">
        <div class="appbar-shell">
            <div class="appbar-brand-row">
                <MudText Typo="Typo.h6">Blazor Options</MudText>
                <MudStack Row="true" Spacing="1" Class="appbar-links">
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Class="appbar-link">Home</MudNavLink>
                    <MudNavLink Href="/trading-history" Class="appbar-link">Trading</MudNavLink>
                    <MudNavLink Href="/data" Class="appbar-link">Data</MudNavLink>
                </MudStack>
            </div>
            <div class="appbar-wallet-row">
                <WalletSummary ShowEquity="true"
                               ShowWalletBalance="true"
                               ShowUpdatedTimestamp="false"
                               CollapseToSingleColumnOnMobile="false"
                               Class="appbar-wallet" />
            </div>
            <div class="appbar-account-group">
                @if (ViewModel.IsAuthenticated && !string.IsNullOrWhiteSpace(ViewModel.UserName))
                {
                    <MudText Typo="Typo.subtitle2">@ViewModel.UserName</MudText>
                }
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                               Class="appbar-account"
                               Color="Color.Inherit"
                               Href="account-settings"
                               aria-label="Account settings" />
            </div>
        </div>
    </MudAppBar>
    <MudMainContent Class="main-content-shell">
        @Body
    </MudMainContent>

    <MudPaper Class="mobile-bottom-nav" Square="true" Elevation="8">
        <div class="mobile-bottom-nav-row">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Class="mobile-bottom-link">
                <span class="mobile-bottom-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Home" />
                </span>
                <MudText Typo="Typo.caption">Home</MudText>
            </MudNavLink>
            <MudNavLink Href="/trading-history" Class="mobile-bottom-link">
                <span class="mobile-bottom-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" />
                </span>
                <MudText Typo="Typo.caption">Trade</MudText>
            </MudNavLink>
            <MudNavLink Href="/data" Class="mobile-bottom-link">
                <span class="mobile-bottom-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" />
                </span>
                <MudText Typo="Typo.caption">Data</MudText>
            </MudNavLink>
            <MudNavLink Href="/account-settings" Class="mobile-bottom-link">
                <span class="mobile-bottom-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" />
                </span>
                <MudText Typo="Typo.caption">Account</MudText>
            </MudNavLink>
        </div>
    </MudPaper>
</MudLayout>

@code {
    protected override void OnInitialized()
    {
        ViewModel.OnChange += HandleViewModelChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnChange -= HandleViewModelChanged;
        ViewModel.Dispose();
    }

    private void HandleViewModelChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}

<style>
    .appbar-shell {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto auto;
        grid-template-areas: "brand brand wallet account";
        align-items: center;
        gap: 12px;
        width: 100%;
        min-width: 0;
    }

    .appbar-brand-row {
        grid-area: brand;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .appbar-wallet-row {
        grid-area: wallet;
        display: flex;
        align-items: center;
        min-width: 0;
    }

    .appbar-account-group {
        grid-area: account;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        min-width: 0;
    }

    .appbar-links {
        margin-left: 16px;
        align-items: center;
    }

    .appbar-link {
        color: inherit;
        text-decoration: none;
        font-weight: 500;
    }

    .appbar-link.active {
        text-decoration: underline;
    }

    .appbar-wallet {
        margin-right: 12px;
    }

    .mobile-bottom-nav {
        display: none;
    }

    .mobile-bottom-nav-row {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        align-items: stretch;
        height: 64px;
    }

    .mobile-bottom-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        min-width: 0 !important;
        text-align: center;
        line-height: 1;
        text-decoration: none;
        padding: 6px 0 !important;
        margin: 0 !important;
    }

    .mobile-bottom-link .mud-icon-root {
        display: block;
        margin: 0 auto;
    }

    .mobile-bottom-icon-wrap {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mobile-bottom-link .mud-typography {
        margin: 0;
        line-height: 1.1;
    }

    .mobile-bottom-link .mud-nav-link-text {
        width: auto !important;
        margin-left: 0 !important;
        margin-inline-start: 0 !important;
        text-align: center !important;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
    }

    @@media (max-width: 768px) {
        .main-appbar {
            height: auto !important;
            min-height: 0 !important;
            display: block !important;
            align-items: stretch !important;
            overflow: visible !important;
            padding-top: calc(env(safe-area-inset-top, 0px) + 8px);
            padding-bottom: 8px;
        }

        .appbar-links {
            display: none;
        }

        .appbar-shell {
            display: grid;
            grid-template-columns: 1fr;
            grid-template-areas:
                "wallet wallet";
            gap: 8px;
            align-items: stretch;
            padding: 8px 0;
        }

        .appbar-brand-row,
        .appbar-wallet-row,
        .appbar-account-group {
            width: 100%;
        }

        .appbar-brand-row,
        .appbar-account-group {
            display: none;
        }

        .appbar-brand-row {
            gap: 8px;
        }

        .appbar-wallet {
            margin-right: 0;
            width: 100%;
        }

        .mobile-bottom-nav {
            display: block;
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 1200;
        }

        .main-content-shell {
            padding-bottom: 72px;
        }
    }
</style>
