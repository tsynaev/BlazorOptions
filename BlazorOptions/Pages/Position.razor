        .mobile-tab-button-active {
            background: #f6aa1c;
            color: #ffffff;
        }
        .mobile-tab-button-inactive {
            background: rgba(148, 163, 184, 0.08);
            color: rgba(255, 255, 255, 0.84);
        }
        .position-sections {
