            gap: 4px;
        }
        .mobile-tab-button {
            flex: 0 0 auto;
            white-space: nowrap;
            min-width: 0;
            min-height: 28px;
            padding: 4px 10px;
            border: 0 !important;
            border-radius: 10px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            line-height: 1;
            text-transform: uppercase;
            box-shadow: none !important;
            background: transparent;
            color: rgba(255, 255, 255, 0.88);
        }
        .mobile-tab-button.mud-button-root {
            border: 0 !important;
