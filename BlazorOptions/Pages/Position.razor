    @@media (min-width: 961px) {
        .mobile-only-section {
            display: none !important;
        }
        .position-desktop-shell {
            flex-direction: row;
            align-items: stretch;
            gap: 16px;
        }
        .position-chart-column {
            flex: 0 0 48%;
            width: 48%;
            position: sticky;
            top: 72px;
            align-self: flex-start;
        }
        .position-mobile-fixed-stack {
            display: contents;
        }
        .position-mobile-fixed-root {
            display: none;
        }
        .position-details-column {
            flex: 1 1 auto;
            height: calc(100vh - 140px);
            overflow-y: auto;
            padding-right: 4px;
        }
