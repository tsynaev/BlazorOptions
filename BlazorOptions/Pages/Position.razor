        .position-page-shell,
        .position-page-shell > .mud-card,
        .position-page-shell > .mud-card > .mud-card-content:first-child {
            margin-top: 0 !important;
            padding-top: 0 !important;
        }
        .main-appbar .appbar-wallet-row {
            display: none !important;
        }
        .position-page-shell {
            height: 100vh;
            overflow: hidden;
        }
        .position-header-surface {
