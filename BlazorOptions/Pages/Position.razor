            display: none;
        }
        .valuation-date-picker,
        .temp-price-field {
            min-width: 0;
            max-width: none;
            width: 100%;
        }
        .valuation-date-slider {
            padding: 0 8px 8px;
        }
        .position-content {
            padding-left: 0;
            padding-right: 0;
        }
