        --position-mobile-header-height: 44px;
        --position-mobile-chart-height: 320px;
        --position-mobile-tabs-height: 44px;
        --position-mobile-fixed-stack-height: calc(var(--position-mobile-header-height) + var(--position-mobile-chart-height) + var(--position-mobile-tabs-height) + 24px);
