            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 60;
            background: var(--mud-palette-background);
        }
        .mobile-position-header {
            display: block;
            background: var(--mud-palette-background);
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
            padding: 0 16px;
        }
        .mobile-position-header > .mud-stack {
            min-height: var(--position-mobile-header-height);
        }
        .position-mobile-chart-shell {
            display: block;
        }
        .position-title {
            font-size: 0.9rem;
